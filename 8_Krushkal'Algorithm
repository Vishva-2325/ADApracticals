#include <stdio.h>
#include <stdlib.h>

struct Edge{int u,v,w;};

int parent[10];

int find(int i){
    while(parent[i]) i=parent[i];
    return i;
}

void uni(int i,int j){
    parent[j]=i;
}

int cmp(const void* a,const void* b){
    return ((struct Edge*)a)->w - ((struct Edge*)b)->w;
}

int main(){
    struct Edge e[]={{0,1,2},{1,2,3},{0,3,6},{1,3,8},{1,4,5}};
    int n=5;

    qsort(e,5,sizeof(e[0]),cmp);

    for(int i=0;i<5;i++){
        int u=find(e[i].u);
        int v=find(e[i].v);
        if(u!=v){
            printf("%d-%d:%d\n",e[i].u,e[i].v,e[i].w);
            uni(u,v);
        }
    }
}
