#include <stdio.h>

int max(int a,int b){ return a>b?a:b; }

int main(){
    int val[]={60,100,120}, wt[]={10,20,30};
    int W=50,n=3;
    int dp[10][50];

    for(int i=0;i<=n;i++){
        for(int w=0;w<=W;w++){
            if(i==0||w==0) dp[i][w]=0;
            else if(wt[i-1]<=w)
                dp[i][w]=max(val[i-1]+dp[i-1][w-wt[i-1]],dp[i-1][w]);
            else dp[i][w]=dp[i-1][w];
        }
    }

    printf("Max value: %d",dp[n][W]);
}
