#include <stdio.h>
#include <limits.h>

int main(){
    int coins[]={1,2,5}, amount=11;
    int dp[100];

    for(int i=0;i<=amount;i++) dp[i]=INT_MAX;
    dp[0]=0;

    for(int i=0;i<3;i++){
        for(int j=coins[i];j<=amount;j++){
            if(dp[j-coins[i]]!=INT_MAX && dp[j]>dp[j-coins[i]]+1)
                dp[j]=dp[j-coins[i]]+1;
        }
    }

    printf("Min coins: %d",dp[amount]);
}
